# =============================================================================
# Stratum — Environment Variables
# Copy this file to .env and fill in the values.
# Generated by ./install.sh — do not commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Project
# -----------------------------------------------------------------------------
PROJECT_NAME=stratum

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=stratum
POSTGRES_USER=stratum
POSTGRES_PASSWORD=changeme

# Full connection URL used by Hasura
DATABASE_URL=postgres://stratum:changeme@postgres:5432/stratum

# -----------------------------------------------------------------------------
# Hasura GraphQL Engine
# -----------------------------------------------------------------------------
HASURA_GRAPHQL_DATABASE_URL=postgres://stratum:changeme@postgres:5432/stratum
HASURA_GRAPHQL_ADMIN_SECRET=changeme-admin-secret
HASURA_GRAPHQL_JWT_SECRET={"type":"HS256","key":"changeme-jwt-secret-min-32-chars!!"}

# Enable Hasura Console (set to false in production)
HASURA_GRAPHQL_ENABLE_CONSOLE=true

# Dev mode (set to false in production)
HASURA_GRAPHQL_DEV_MODE=true

# Log level: debug | info | warn | error
HASURA_GRAPHQL_LOG_LEVEL=info

# Hasura endpoint — used by NestJS to call Hasura internally
HASURA_GRAPHQL_ENDPOINT=http://hasura:8080

# Shared secret for Hasura → NestJS webhook calls (Actions, Event Triggers)
HASURA_EVENT_SECRET=changeme-event-secret

# -----------------------------------------------------------------------------
# NestJS
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# NestJS needs these to make internal calls back to Hasura
# (same values as above, repeated for clarity)
HASURA_ENDPOINT=http://hasura:8080
HASURA_ADMIN_SECRET=changeme-admin-secret

# -----------------------------------------------------------------------------
# S3 Object Storage (optional — only needed if STORAGE_ENABLED=true)
# Compatible with any S3-compatible engine: RustFS, MinIO, AWS S3, etc.
# Web Console available at http://localhost:9001 when storage is enabled.
# -----------------------------------------------------------------------------
STORAGE_ENABLED=false

S3_ENDPOINT=http://rustfs:9000
S3_ACCESS_KEY=changeme-access-key
S3_SECRET_KEY=changeme-secret-key
S3_DEFAULT_BUCKET=uploads
S3_REGION=us-east-1
